---
import IconPhone from './icons/IconPhone.astro';
import IconMail from './icons/IconMail.astro';
import IconMapPin from './icons/IconMapPin.astro';

const year = new Date().getFullYear();
---

<footer class="bg-primary-950 text-accent-300 mt-auto">
  <!-- Gradient divider -->
  <div class="h-1 bg-gradient-to-r from-primary-700 via-primary-500 to-primary-700"></div>

  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-9 h-9 rounded-lg bg-primary-600 flex items-center justify-center font-extrabold text-sm text-white">
            SK
          </div>
          <span class="text-lg font-bold text-white tracking-tight">Skandi Klubb</span>
        </div>
        <p class="text-sm text-accent-400 leading-relaxed">
          Информационный портал для жителей ЖК Skandi Klubb.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Навигация</h4>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-sm text-accent-400 hover:text-white transition-colors">Дом</a></li>
          <li><a href="/management" class="text-sm text-accent-400 hover:text-white transition-colors">Управляющая компания</a></li>
          <li><a href="/problems" class="text-sm text-accent-400 hover:text-white transition-colors">Проблемы</a></li>
          <li><a href="/complaints" class="text-sm text-accent-400 hover:text-white transition-colors">Жалобы</a></li>
          <li><a href="/contract" class="text-sm text-accent-400 hover:text-white transition-colors">Договор управления</a></li>
          <li><a href="/rights" class="text-sm text-accent-400 hover:text-white transition-colors">Ваши права</a></li>
          <li><a href="/oss" class="text-sm text-accent-400 hover:text-white transition-colors">ОСС 2025</a></li>
        </ul>
      </div>

      <!-- Contacts -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Диспетчерская УК</h4>
        <ul class="space-y-3">
          <li>
            <a href="tel:+78126779802" class="flex items-center gap-2.5 text-sm text-accent-400 hover:text-white transition-colors">
              <IconPhone size={16} class="shrink-0 text-primary-400" />
              +7 (812) 677-98-02
            </a>
          </li>
          <li>
            <a href="mailto:info@ecvida-service.ru" class="flex items-center gap-2.5 text-sm text-accent-400 hover:text-white transition-colors">
              <IconMail size={16} class="shrink-0 text-primary-400" />
              info@ecvida-service.ru
            </a>
          </li>
          <li>
            <a href="https://t.me/skandi_uk" target="_blank" rel="noopener" class="flex items-center gap-2.5 text-sm text-accent-400 hover:text-white transition-colors">
              <svg class="shrink-0 text-primary-400 w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              @skandi_uk
            </a>
          </li>
        </ul>
      </div>

      <!-- Address -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Адрес</h4>
        <div class="flex items-start gap-2.5 text-sm text-accent-400">
          <IconMapPin size={16} class="shrink-0 mt-0.5 text-primary-400" />
          <span>
            Санкт-Петербург,<br />
            Аптекарский пр-кт, 18,<br />
            лит. А
          </span>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="border-t border-white/10 mt-10 pt-6">
      <p class="text-xs text-accent-500 text-center max-w-2xl mx-auto leading-relaxed mb-4">
        Сайт носит информационно-справочный характер. Информация собрана из открытых источников и обращений жителей. Возможны неточности. Если вы нашли ошибку или хотите дополнить информацию — напишите нам.
      </p>
      <div class="flex items-center justify-center gap-3">
        <span class="text-xs text-accent-500">&copy; {year} Skandi Klubb</span>
        <a href="https://t.me/Hegemon78" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-xs text-accent-500 hover:text-primary-400 transition-colors" title="Написать в Telegram">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Написать
        </a>
      </div>
    </div>
  </div>
</footer>
