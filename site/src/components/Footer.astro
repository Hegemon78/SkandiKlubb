---
const year = new Date().getFullYear();
---

<footer class="bg-accent-950 text-accent-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-3">Skandi Klubb</h3>
        <p class="text-sm">
          Информационный портал для жителей<br />
          ЖК Skandi Klubb
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-3">Диспетчерская УК</h4>
        <p class="text-sm">
          <a href="tel:+78126779802" class="hover:text-white transition-colors">
            +7 (812) 677-98-02
          </a>
        </p>
        <p class="text-sm mt-1">
          <a href="mailto:info@ecvida-service.ru" class="hover:text-white transition-colors">
            info@ecvida-service.ru
          </a>
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-3">Адрес</h4>
        <p class="text-sm">
          Санкт-Петербург,<br />
          Аптекарский пр-кт, 18, лит. А
        </p>
