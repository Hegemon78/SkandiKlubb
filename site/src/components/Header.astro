---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/about', label: 'Дом' },
  { href: '/management', label: 'УК' },
  { href: '/problems', label: 'Проблемы' },
  { href: '/faq', label: 'FAQ' },
  { href: '/complaints', label: 'Жалобы' },
  { href: '/generator', label: 'Генератор' },
  { href: '/oss', label: 'ОСС 2025' },
];

const mobileNavLinks = [
  { href: '/', label: 'Главная' },
  ...navLinks,
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    transparent ? 'header-transparent' : 'bg-white shadow-sm'
  ]}
  data-transparent={transparent ? 'true' : 'false'}
>
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class:list={[
          'w-9 h-9 rounded-lg flex items-center justify-center font-extrabold text-sm transition-colors duration-300',
          transparent ? 'bg-white/20 text-white logo-box' : 'bg-primary-600 text-white'
        ]}>
          SK
        </div>
        <span class:list={[
          'text-lg font-bold tracking-tight transition-colors duration-300',
          transparent ? 'text-white logo-text' : 'text-primary-950'
        ]}>
          Skandi Klubb
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'nav-link px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200',
              isActive(link.href)
                ? (transparent ? 'bg-white/20 text-white nav-active' : 'bg-primary-50 text-primary-700')
                : (transparent ? 'text-white/80 hover:text-white hover:bg-white/10 nav-default' : 'text-accent-600 hover:text-primary-700 hover:bg-primary-50')
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile: phone + burger -->
      <div class="flex items-center gap-1 md:hidden">
        <a
          href="tel:+78126779802"
          class:list={[
            'p-2 rounded-lg transition-colors',
            transparent ? 'text-white hover:bg-white/10 burger-btn' : 'text-primary-600 hover:bg-primary-50'
          ]}
          aria-label="Позвонить диспетчеру"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </a>
        <button
          id="mobile-menu-btn"
          class:list={[
            'p-2 rounded-lg transition-colors',
            transparent ? 'text-white hover:bg-white/10 burger-btn' : 'text-accent-600 hover:bg-accent-100'
          ]}
          aria-label="Открыть меню"
        >
          <svg id="burger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <line x1="4" x2="20" y1="6" y2="6" stroke-width="2" stroke-linecap="round"/>
            <line x1="4" x2="20" y1="12" y2="12" stroke-width="2" stroke-linecap="round"/>
            <line x1="4" x2="20" y1="18" y2="18" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M18 6 6 18" stroke-width="2" stroke-linecap="round"/>
            <path d="m6 6 12 12" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="hidden md:hidden overflow-hidden transition-all duration-300 max-h-0 border-b border-accent-200/0" data-border>
      <div class="pb-4 pt-3 px-2">
        <div class="grid grid-cols-2 gap-2">
          {mobileNavLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'text-center px-3 py-3.5 rounded-xl text-base font-medium transition-colors',
                isActive(link.href)
                  ? 'bg-primary-50 text-primary-700 font-semibold'
                  : 'text-accent-700 hover:bg-accent-50 hover:text-primary-700'
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
        <a href="tel:+78126779802" class="block w-full text-center px-4 py-3.5 rounded-xl text-base font-medium bg-primary-600 text-white mt-3">
          Позвонить диспетчеру
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer to prevent content from going under fixed header -->
<div class:list={[transparent ? '' : 'h-16']}></div>

<script>
  const header = document.getElementById('site-header');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const burgerIcon = document.getElementById('burger-icon');
  const closeIcon = document.getElementById('close-icon');
  const isTransparent = header?.dataset.transparent === 'true';
  let menuOpen = false;

  // Scroll-aware header for transparent mode
  if (isTransparent && header) {
    const onScroll = () => {
      // Don't restore transparency while mobile menu is open
      if (menuOpen) return;
      if (window.scrollY > 50) {
        header.classList.remove('header-transparent');
        header.classList.add('bg-white', 'shadow-sm', 'header-scrolled');
      } else {
        header.classList.add('header-transparent');
        header.classList.remove('bg-white', 'shadow-sm', 'header-scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu toggle
  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      menu?.classList.remove('max-h-0', 'hidden');
      menu?.classList.add('max-h-[500px]');
      menu?.classList.replace('border-accent-200/0', 'border-accent-200');
      // Force white header when menu is open (even in transparent mode)
      if (isTransparent && header) {
        header.classList.remove('header-transparent');
        header.classList.add('bg-white', 'shadow-sm', 'header-scrolled');
      }
    } else {
      menu?.classList.add('max-h-0');
      menu?.classList.remove('max-h-[500px]');
      menu?.classList.replace('border-accent-200', 'border-accent-200/0');
      // Restore transparent header if at top
      if (isTransparent && header && window.scrollY <= 50) {
        header.classList.add('header-transparent');
        header.classList.remove('bg-white', 'shadow-sm', 'header-scrolled');
      }
    }
    burgerIcon?.classList.toggle('hidden', menuOpen);
    closeIcon?.classList.toggle('hidden', !menuOpen);
  });
</script>

<style>
  /* Transparent header → scrolled: recolor elements */
  .header-scrolled .logo-box {
    background-color: var(--color-primary-600);
    color: white;
  }
  .header-scrolled .logo-text {
    color: var(--color-primary-950);
  }
  .header-scrolled .nav-link.nav-active {
    background-color: var(--color-primary-50);
    color: var(--color-primary-700);
  }
  .header-scrolled .nav-link.nav-default {
    color: var(--color-accent-600);
  }
  .header-scrolled .nav-link.nav-default:hover {
    color: var(--color-primary-700);
    background-color: var(--color-primary-50);
  }
  .header-scrolled .burger-btn {
    color: var(--color-accent-600);
  }
</style>
