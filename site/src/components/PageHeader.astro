---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, description, breadcrumbs = [] } = Astro.props;
---

<section class="bg-primary-950 text-white pt-24 pb-12">
  <div class="max-w-5xl mx-auto px-4">
    {breadcrumbs.length > 0 && (
      <nav class="flex items-center gap-2 text-sm text-primary-300 mb-4">
        <a href="/" class="hover:text-white transition-colors">Главная</a>
        {breadcrumbs.map((item) => (
          <>
            <span class="text-primary-600">/</span>
            {item.href ? (
              <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
            ) : (
              <span class="text-primary-200">{item.label}</span>
            )}
          </>
        ))}
      </nav>
    )}
    <h1 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight">{title}</h1>
    {description && (
      <p class="mt-3 text-lg text-primary-200 max-w-2xl">{description}</p>
    )}
  </div>
</section>
