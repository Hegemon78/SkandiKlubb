---
interface Props {
  title: string;
  slug: string;
  category: string;
  summary: string;
}

const { title, slug, category, summary } = Astro.props;
---

<a
  href={`/problems/${slug}`}
  class="group block bg-white rounded-xl border border-accent-200 shadow-sm p-3 md:p-4 hover:shadow-md hover:border-primary-300 active:scale-[0.98] transition-all duration-200"
>
  <div class="flex items-center gap-2">
    <div class="min-w-0 flex-1">
      <h4 class="text-sm font-bold text-primary-950 group-hover:text-primary-700 transition-colors leading-snug">{title}</h4>
      <p class="hidden md:block text-xs text-accent-500 mt-1 line-clamp-1">{summary}</p>
    </div>
    <svg class="w-4 h-4 text-primary-400 group-hover:text-primary-600 shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path d="m9 18 6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>
