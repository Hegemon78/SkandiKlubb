---
interface Props {
  title: string;
  slug: string;
  category: string;
  summary: string;
}

const { title, slug, category, summary } = Astro.props;

const categoryColors: Record<string, string> = {
  'Безопасность': 'border-l-red-500',
  'Технические': 'border-l-blue-500',
  'Финансовые': 'border-l-amber-500',
  'Организационные': 'border-l-purple-500',
};

const borderClass = categoryColors[category] || 'border-l-accent-300';
---

<a
  href={`/problems/${slug}`}
  class:list={['group block bg-white rounded-xl border border-accent-200 border-l-4 p-4 hover:shadow-md transition-all duration-300', borderClass]}
>
  <div class="flex items-start justify-between gap-2">
    <div class="min-w-0">
      <span class="text-xs font-medium text-accent-500 uppercase tracking-wider">{category}</span>
      <h4 class="text-sm font-bold text-primary-950 mt-1 group-hover:text-primary-600 transition-colors leading-snug">{title}</h4>
      <p class="text-xs text-accent-600 mt-1 line-clamp-2">{summary}</p>
    </div>
    <svg class="w-4 h-4 text-accent-400 group-hover:text-primary-600 shrink-0 mt-1 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path d="m9 18 6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>
