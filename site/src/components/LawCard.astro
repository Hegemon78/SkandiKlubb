---
import type { LawCard } from '../data/rights';
import { categoryLabels, categoryColors } from '../data/rights';

interface Props {
  law: LawCard;
}

const { law } = Astro.props;
---

<div class="bg-white rounded-xl border border-accent-200 p-4 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-2 mb-2">
    <span class:list={['inline-flex text-xs font-medium px-2 py-0.5 rounded-full border', categoryColors[law.category]]}>
      {categoryLabels[law.category]}
    </span>
  </div>
  <h4 class="text-sm font-bold text-primary-950 mb-1">{law.title}</h4>
  <p class="text-xs font-semibold text-primary-600 mb-2">{law.article}</p>
  <p class="text-sm text-accent-600 leading-relaxed">{law.description}</p>
</div>
