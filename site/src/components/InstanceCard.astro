---
interface Props {
  step: number;
  name: string;
  description: string;
  phone?: string;
  email?: string;
  address?: string;
  url?: string;
  deadline: string;
  basis?: string;
}

const { step, name, description, phone, email, address, url, deadline, basis } = Astro.props;
---

<div class="bg-white rounded-xl border border-accent-200 p-5 relative">
  <div class="absolute -top-3 -left-2 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-md">
    {step}
  </div>

  <h3 class="text-lg font-bold text-primary-900 mb-2 ml-6">{name}</h3>
  <p class="text-sm text-accent-600 mb-4">{description}</p>

  <div class="space-y-1.5 text-sm">
    {phone && (
      <div class="flex items-center gap-2">
        <span class="text-accent-400 w-5 text-center">T</span>
        <a href={`tel:${phone.replace(/[^\d+]/g, '')}`} class="text-primary-600 hover:underline">{phone}</a>
      </div>
    )}
    {email && (
      <div class="flex items-center gap-2">
        <span class="text-accent-400 w-5 text-center">@</span>
        {email.startsWith('TODO') ? (
          <span class="text-accent-400 italic">Уточняется</span>
        ) : (
          <a href={`mailto:${email}`} class="text-primary-600 hover:underline">{email}</a>
        )}
      </div>
    )}
    {address && (
      <div class="flex items-center gap-2">
        <span class="text-accent-400 w-5 text-center">A</span>
        {address.startsWith('TODO') ? (
          <span class="text-accent-400 italic">Уточняется</span>
        ) : (
          <span class="text-accent-700">{address}</span>
        )}
      </div>
    )}
    {url && (
      <div class="flex items-center gap-2">
        <span class="text-accent-400 w-5 text-center">W</span>
        <a href={url} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">{url}</a>
      </div>
    )}
  </div>

  <div class="mt-4 pt-3 border-t border-accent-100 flex items-center justify-between text-xs text-accent-500">
    <span>Срок ответа: {deadline}</span>
    {basis && <span>{basis}</span>}
  </div>
</div>
