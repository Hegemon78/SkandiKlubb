---
import IconPhone from './icons/IconPhone.astro';
import IconMail from './icons/IconMail.astro';
import IconMapPin from './icons/IconMapPin.astro';
import IconGlobe from './icons/IconGlobe.astro';
import IconClock from './icons/IconClock.astro';
import IconScale from './icons/IconScale.astro';

interface Props {
  step: number;
  name: string;
  description: string;
  phone?: string;
  email?: string;
  address?: string;
  url?: string;
  deadline: string;
  basis?: string;
}

const { step, name, description, phone, email, address, url, deadline, basis } = Astro.props;
---

<div class:list={[
  'bg-white rounded-2xl p-6 relative hover:shadow-md transition-all duration-300',
  (email?.startsWith('TODO') || address?.startsWith('TODO')) ? 'border-2 border-dashed border-accent-300' : 'border border-accent-200'
]}>
  <div class="absolute -top-3 -left-2 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center text-sm font-bold shadow-md">
    {step}
  </div>

  <h3 class="text-lg font-bold text-primary-950 mb-2 ml-6">{name}</h3>
  <p class="text-sm text-accent-600 mb-4 leading-relaxed">{description}</p>

  <div class="space-y-2 text-sm">
    {phone && (
      <div class="flex items-center gap-2.5">
        <IconPhone size={16} class="text-accent-400 shrink-0" />
        <a href={`tel:${phone.replace(/[^\d+]/g, '')}`} class="text-primary-600 hover:underline">{phone}</a>
      </div>
    )}
    {email && (
      <div class="flex items-center gap-2.5">
        <IconMail size={16} class="text-accent-400 shrink-0" />
        {email.startsWith('TODO') ? (
          <span class="text-accent-400 italic">Уточняется</span>
        ) : (
          <a href={`mailto:${email}`} class="text-primary-600 hover:underline">{email}</a>
        )}
      </div>
    )}
    {address && (
      <div class="flex items-center gap-2.5">
        <IconMapPin size={16} class="text-accent-400 shrink-0" />
        {address.startsWith('TODO') ? (
          <span class="text-accent-400 italic">Уточняется</span>
        ) : (
          <span class="text-accent-700">{address}</span>
        )}
      </div>
    )}
    {url && (
      <div class="flex items-center gap-2.5">
        <IconGlobe size={16} class="text-accent-400 shrink-0" />
        <a href={url} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline truncate">{url}</a>
      </div>
    )}
  </div>

  <div class="mt-4 pt-3 border-t border-accent-100 flex items-center justify-between text-xs text-accent-500">
    <span class="flex items-center gap-1.5">
      <IconClock size={14} class="text-accent-400" />
      Срок: {deadline}
    </span>
    {basis && (
      <span class="flex items-center gap-1.5">
        <IconScale size={14} class="text-accent-400" />
        {basis}
      </span>
    )}
  </div>

  <a
    href="/generator"
    class="mt-4 w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-primary-600 text-white text-sm font-medium hover:bg-primary-700 active:scale-[0.98] transition-all"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" stroke-width="2"/><rect x="9" y="3" width="6" height="4" rx="1" stroke-width="2"/></svg>
    Составить жалобу
  </a>
</div>
