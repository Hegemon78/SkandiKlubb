---
interface Props {
  current: number;
  total: number;
  label?: string;
}

const { current, total, label } = Astro.props;
const percent = Math.round((current / total) * 100);
---

<div class="bg-white rounded-2xl border border-accent-200 p-6">
  <div class="flex items-center justify-between mb-3">
    {label && <span class="text-sm font-medium text-primary-950">{label}</span>}
    <span class="text-sm text-accent-600">{current} из {total}</span>
  </div>
  <div class="w-full h-3 bg-accent-100 rounded-full overflow-hidden">
    <div
      class="h-full bg-gradient-to-r from-primary-500 to-primary-600 rounded-full transition-all duration-500"
      style={`width: ${percent}%`}
    ></div>
  </div>
  <div class="text-xs text-accent-500 mt-2 text-right">{percent}% готово</div>
</div>
