---
interface Props {
  href: string;
  title: string;
  description?: string;
  fact?: string;
  iconColor?: string;
  comingSoon?: boolean;
}

const { href, title, description, fact, iconColor = 'text-primary-600', comingSoon = false } = Astro.props;
---

{comingSoon ? (
  <div class="bg-white/80 rounded-xl border-2 border-dashed border-accent-200 p-3.5 md:p-5 flex items-center gap-3">
    <div class="w-10 h-10 rounded-lg bg-accent-100 flex items-center justify-center shrink-0">
      <slot />
    </div>
    <div class="min-w-0">
      <h3 class="text-sm font-semibold text-accent-400">{title}</h3>
      <p class="text-xs text-accent-400 mt-0.5">{description}</p>
    </div>
  </div>
) : (
  <a
    href={href}
    class="group bg-white rounded-xl shadow-sm ring-1 ring-black/[0.04] p-3.5 md:p-5 flex items-center gap-3 hover:shadow-md hover:ring-primary-200/50 active:scale-[0.98] transition-all duration-200"
  >
    <div class:list={['w-10 h-10 rounded-lg flex items-center justify-center shrink-0', iconColor === 'text-primary-600' ? 'bg-primary-50' : 'bg-accent-50']}>
      <slot />
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="text-[13px] md:text-base font-semibold text-primary-950 group-hover:text-primary-700 transition-colors">{title}</h3>
      {fact && (
        <p class="text-[11px] md:text-xs text-accent-500 mt-0.5 truncate">{fact}</p>
      )}
    </div>
    <svg class="w-4 h-4 text-accent-300 shrink-0 group-hover:text-primary-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
)}
