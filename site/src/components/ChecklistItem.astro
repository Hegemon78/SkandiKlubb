---
interface Props {
  id: number;
  obligation: string;
  clause: string;
  status: 'violated' | 'partial' | 'unknown';
  comment?: string;
}

const { id, obligation, clause, status, comment } = Astro.props;

const statusConfig = {
  violated: { label: 'Нарушается', bg: 'bg-red-50/60', text: 'text-red-600/80', dot: 'bg-red-300', icon: 'x' },
  partial: { label: 'Частично', bg: 'bg-amber-50/60', text: 'text-amber-600/80', dot: 'bg-amber-300', icon: '~' },
  unknown: { label: 'Неизвестно', bg: 'bg-accent-50', text: 'text-accent-500', dot: 'bg-accent-400', icon: '?' },
};

const cfg = statusConfig[status];
---

<div class="flex items-start gap-3 py-3 border-b border-accent-100 last:border-0">
  <span class:list={['w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 mt-0.5', cfg.bg, cfg.text]}>
    {cfg.icon === 'x' ? (
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12" stroke-width="2.5" stroke-linecap="round"/></svg>
    ) : cfg.icon === '~' ? (
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14" stroke-width="2.5" stroke-linecap="round"/></svg>
    ) : (
      <span>?</span>
    )}
  </span>
  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2">
      <p class="text-sm text-primary-950 font-medium">{obligation}</p>
      <span class:list={['inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full whitespace-nowrap shrink-0', cfg.bg, cfg.text]}>
        <span class:list={['w-1.5 h-1.5 rounded-full', cfg.dot]}></span>
        {cfg.label}
      </span>
    </div>
    <p class="text-xs text-accent-400 mt-0.5">{clause}</p>
    {comment && <p class="text-xs text-accent-500 mt-1 italic">{comment}</p>}
  </div>
</div>
