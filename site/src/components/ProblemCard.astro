---
interface Props {
  title: string;
  slug: string;
  category: string;
  priority: 'high' | 'medium' | 'low';
  status: string;
  summary: string;
  discussionCount?: number;
}

const { title, slug, category, priority, status, summary, discussionCount } = Astro.props;

const priorityColors = {
  high: 'bg-red-50 text-red-700 border border-red-200',
  medium: 'bg-amber-50 text-amber-700 border border-amber-200',
  low: 'bg-green-50 text-green-700 border border-green-200',
};

const priorityLabels = {
  high: 'Высокий',
  medium: 'Средний',
  low: 'Низкий',
};

const categoryBorders: Record<string, string> = {
  'Безопасность': 'border-l-red-500',
  'Технические': 'border-l-primary-500',
  'Финансовые': 'border-l-amber-500',
  'Организационные': 'border-l-purple-500',
};

const borderClass = categoryBorders[category] || '';
---

<a
  href={`/problems/${slug}`}
  class:list={['group block bg-white rounded-xl border border-accent-200 border-l-4 p-4 md:p-5 hover:shadow-md transition-all duration-200', borderClass]}
>
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="text-base font-bold text-primary-950 group-hover:text-primary-600 transition-colors leading-snug">
      {title}
    </h3>
    <span class:list={['text-[11px] font-medium px-2 py-0.5 rounded-full whitespace-nowrap shrink-0', priorityColors[priority]]}>
      {priorityLabels[priority]}
    </span>
  </div>

  <p class="text-sm text-accent-600 mb-3 line-clamp-2 leading-snug">{summary}</p>

  <div class="flex items-center gap-3 text-xs text-accent-400">
    <span class="truncate">{status}</span>
    {discussionCount && discussionCount > 0 && (
      <span class="text-primary-500 font-medium inline-flex items-center gap-1 shrink-0">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke-width="1.5"/></svg>
        {discussionCount}
      </span>
    )}
  </div>
</a>
