---
interface Props {
  title: string;
  slug: string;
  category: string;
  priority: 'high' | 'medium' | 'low';
  status: string;
  summary: string;
}

const { title, slug, category, priority, status, summary } = Astro.props;

const priorityColors = {
  high: 'bg-red-50 text-red-700 border border-red-200',
  medium: 'bg-amber-50 text-amber-700 border border-amber-200',
  low: 'bg-green-50 text-green-700 border border-green-200',
};

const priorityLabels = {
  high: 'Высокий',
  medium: 'Средний',
  low: 'Низкий',
};
---

<a
  href={`/problems/${slug}`}
  class="group block bg-white rounded-2xl border border-accent-200 p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
>
  <div class="flex items-start justify-between mb-3">
    <span class="text-xs font-semibold text-accent-500 uppercase tracking-wider">{category}</span>
    <span class:list={['text-xs font-medium px-2.5 py-1 rounded-full', priorityColors[priority]]}>
      {priorityLabels[priority]}
    </span>
  </div>

  <h3 class="text-lg font-bold text-primary-950 mb-2 group-hover:text-primary-600 transition-colors leading-snug">
    {title}
  </h3>

  <p class="text-sm text-accent-600 mb-4 line-clamp-2 leading-relaxed">{summary}</p>

  <div class="flex items-center justify-between">
    <span class="text-xs text-accent-400">{status}</span>
    <span class="text-primary-600 text-sm font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
      Подробнее
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 12h14" stroke-width="2" stroke-linecap="round"/><path d="m12 5 7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</a>
