---
interface StatItem {
  value: string | number;
  label: string;
}

interface Props {
  stats: StatItem[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
  {stats.map(stat => (
    <div class="bg-primary-50 rounded-xl p-4 text-center border border-primary-100">
      <div class="text-2xl font-extrabold text-primary-700">{stat.value}</div>
      <div class="text-xs text-accent-600 mt-1">{stat.label}</div>
    </div>
  ))}
</div>
