---
interface StatItem {
  value: string | number;
  label: string;
}

interface Props {
  stats: StatItem[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
  {stats.map(stat => (
    <div class="bg-primary-50 rounded-lg p-2.5 text-center">
      <div class="text-lg font-extrabold text-primary-700">{stat.value}</div>
      <div class="text-xs text-accent-600 mt-0.5">{stat.label}</div>
    </div>
  ))}
</div>
