---
interface Props {
  status: 'collecting' | 'preparing' | 'ready' | 'investigation';
  size?: 'sm' | 'md';
}

const { status, size = 'sm' } = Astro.props;

const config = {
  collecting: { label: 'Сбор информации', color: 'bg-amber-50/60 text-amber-600/80', dot: 'bg-amber-300' },
  preparing: { label: 'Подготовка', color: 'bg-primary-50 text-primary-600', dot: 'bg-primary-300' },
  ready: { label: 'Готово', color: 'bg-green-50/60 text-green-600/80', dot: 'bg-green-300' },
  investigation: { label: 'Требуются изыскания', color: 'bg-purple-50/60 text-purple-600/80', dot: 'bg-purple-300' },
};

const { label, color, dot } = config[status];
const sizeClass = size === 'sm' ? 'text-xs px-2.5 py-1' : 'text-sm px-3 py-1.5';
---

<span class:list={['inline-flex items-center gap-1.5 rounded-full font-medium', color, sizeClass]}>
  <span class:list={['w-1.5 h-1.5 rounded-full', dot]}></span>
  {label}
</span>
