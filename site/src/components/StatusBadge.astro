---
interface Props {
  status: 'collecting' | 'preparing' | 'ready' | 'investigation';
  size?: 'sm' | 'md';
}

const { status, size = 'sm' } = Astro.props;

const config = {
  collecting: { label: 'Сбор информации', color: 'bg-yellow-100 text-yellow-800' },
  preparing: { label: 'Подготовка', color: 'bg-blue-100 text-blue-800' },
  ready: { label: 'Готово', color: 'bg-green-100 text-green-800' },
  investigation: { label: 'Требуются изыскания', color: 'bg-purple-100 text-purple-800' },
};

const { label, color } = config[status];
const sizeClass = size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-sm px-3 py-1';
---

<span class:list={['inline-block rounded-full font-medium', color, sizeClass]}>
  {label}
</span>
