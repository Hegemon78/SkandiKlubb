---
interface Props {
  status: 'collecting' | 'preparing' | 'ready' | 'investigation';
  size?: 'sm' | 'md';
}

const { status, size = 'sm' } = Astro.props;

const config = {
  collecting: { label: 'Сбор информации', color: 'bg-amber-50 text-amber-700', dot: 'bg-amber-400' },
  preparing: { label: 'Подготовка', color: 'bg-blue-50 text-blue-700', dot: 'bg-blue-400' },
  ready: { label: 'Готово', color: 'bg-green-50 text-green-700', dot: 'bg-green-400' },
  investigation: { label: 'Требуются изыскания', color: 'bg-purple-50 text-purple-700', dot: 'bg-purple-400' },
};

const { label, color, dot } = config[status];
const sizeClass = size === 'sm' ? 'text-xs px-2.5 py-1' : 'text-sm px-3 py-1.5';
---

<span class:list={['inline-flex items-center gap-1.5 rounded-full font-medium', color, sizeClass]}>
  <span class:list={['w-1.5 h-1.5 rounded-full', dot]}></span>
  {label}
</span>
