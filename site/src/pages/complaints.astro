---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstanceCard from '../components/InstanceCard.astro';
import { instances, escalationSteps } from '../data/instances';
---

<BaseLayout title="Куда жаловаться" description="Реестр инстанций Санкт-Петербурга для подачи жалоб на управляющую компанию">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-2">Куда жаловаться</h1>
    <p class="text-accent-600 mb-8">
      Реестр инстанций Санкт-Петербурга. Район: Петроградский.
    </p>

    <!-- Escalation -->
    <div class="bg-primary-50 rounded-xl p-6 mb-10 border border-primary-200">
      <h2 class="text-xl font-bold text-primary-900 mb-4">Порядок эскалации</h2>
      <div class="space-y-3">
        {escalationSteps.map((step, i) => (
          <div class="flex items-start gap-3">
            <div class="w-7 h-7 rounded-full bg-primary-600 text-white flex items-center justify-center text-sm font-bold shrink-0">
              {i + 1}
            </div>
            <div class="pt-0.5">
              <p class="text-accent-700">{step}</p>
              {i < escalationSteps.length - 1 && (
                <div class="text-primary-400 text-xs mt-1 ml-1">&darr;</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Instances -->
    <h2 class="text-2xl font-bold text-primary-900 mb-6">Инстанции</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {instances.map(inst => (
        <InstanceCard
          step={inst.step}
          name={inst.name}
          description={inst.description}
          phone={inst.phone}
          email={inst.email}
          address={inst.address}
          url={inst.url}
          deadline={inst.deadline}
          basis={inst.basis}
        />
      ))}
    </div>

    <!-- Note -->
    <div class="mt-10 p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>Важно:</strong> Всегда фиксируйте обращения письменно. Отправляйте заказные письма или
      получайте отметку о вручении. Дублируйте обращения через ГИС ЖКХ для электронной фиксации.
    </div>
  </section>
</BaseLayout>
