---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import EscalationChain from '../components/EscalationChain.astro';
import InstanceCard from '../components/InstanceCard.astro';
import IconInfo from '../components/icons/IconInfo.astro';
import { instances, escalationSteps } from '../data/instances';
---

<BaseLayout title="Жалобы" description="Реестр инстанций Санкт-Петербурга для подачи жалоб на управляющую компанию">
  <PageHeader
    title="Куда жаловаться"
    description="Реестр инстанций Санкт-Петербурга. Район: Петроградский."
    breadcrumbs={[{ label: 'Жалобы' }]}
  />

  <section class="max-w-5xl mx-auto px-4 py-12">
    <!-- Summary -->
    <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-5 mb-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
      <span class="font-bold text-primary-950">{instances.length} инстанций</span>
      <span class="text-accent-600">от 10 до 30 дней на ответ</span>
    </div>

    <!-- Escalation chain -->
    <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-6 md:p-8 mb-12">
      <h2 class="text-xl font-bold text-primary-950 mb-6">Порядок эскалации</h2>
      <EscalationChain steps={escalationSteps} />
    </div>

    <!-- Instances -->
    <h2 class="text-2xl font-bold text-primary-950 mb-6">Инстанции</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      {instances.map((inst, i) => (
        <div class="animate-fade-in" style={`transition-delay: ${i * 80}ms`}>
          <InstanceCard
            step={inst.step}
            name={inst.name}
            description={inst.description}
            phone={inst.phone}
            email={inst.email}
            address={inst.address}
            url={inst.url}
            deadline={inst.deadline}
            basis={inst.basis}
          />
        </div>
      ))}
    </div>

    <!-- Note -->
    <div class="animate-fade-in flex items-start gap-3 p-5 bg-amber-50 border border-amber-200 rounded-2xl text-sm text-amber-800">
      <IconInfo size={20} class="text-amber-500 shrink-0 mt-0.5" />
      <div>
        <strong>Важно:</strong> Всегда фиксируйте обращения письменно. Отправляйте заказные письма или
        получайте отметку о вручении. Дублируйте обращения через ГИС ЖКХ для электронной фиксации.
      </div>
    </div>
  </section>
</BaseLayout>
