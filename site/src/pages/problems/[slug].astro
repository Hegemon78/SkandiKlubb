---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import ComplaintCTA from '../../components/ComplaintCTA.astro';
import { getCollection, render } from 'astro:content';
import { problemLawLinks } from '../../data/rights';
import { complaintTemplates } from '../../data/complaint-templates';
import problemStats from '../../data/generated/problem-stats.json';
import solutionsData from '../../data/generated/solutions.json';

export async function getStaticPaths() {
  const problems = await getCollection('problems');
  return problems.map(problem => ({
    params: { slug: problem.id },
    props: { problem },
  }));
}

const { problem } = Astro.props;
const { Content } = await render(problem);
const lawLink = problemLawLinks.find(l => l.problemSlug === problem.id);

// Find matching parser data for this problem slug
const slugToSubcats: Record<string, string[]> = {
  parking: ['parking'],
  skud: ['skud', 'intercom'],
  communications: ['water', 'elevator'],
  repair: ['repair'],
  territory: ['territory', 'cleaning', 'lighting'],
  video: ['cameras'],
  security: ['security'],
  'management-quality': ['uk'],
  'capital-repair': ['fees'],
};
const matchingSubcats = slugToSubcats[problem.id] || [];

// Collect quotes from matching subcategories
const quotes: string[] = [];
const discussionCount = matchingSubcats.reduce((acc, subcat) => {
  return acc + ((problemStats.discussionCounts as Record<string, number>)[subcat] || 0);
}, 0);

for (const stat of (problemStats.bySubcategory as any[])) {
  if (matchingSubcats.includes(stat.subcategory) && stat.quotes) {
    quotes.push(...stat.quotes);
  }
}

// Collect solutions
const solutions: Array<{text: string; date: string | null}> = [];
for (const sol of (solutionsData as any[])) {
  if (matchingSubcats.includes(sol.subcategory) && sol.items) {
    solutions.push(...sol.items.slice(0, 5));
  }
}

const priorityLabels = {
  high: 'Высокий',
  medium: 'Средний',
  low: 'Низкий',
};

const priorityColors = {
  high: 'text-red-600',
  medium: 'text-amber-600',
  low: 'text-green-600',
};

const templateCount = complaintTemplates.filter(t => t.problemSlug === problem.id).length;
const hasTemplates = templateCount > 0;
---

<BaseLayout title={problem.data.title} description={problem.data.summary}>
  <PageHeader
    title={problem.data.title}
    breadcrumbs={[
      { label: 'Проблемы', href: '/problems' },
      { label: problem.data.title }
    ]}
  />

  <section class="max-w-5xl mx-auto px-4 py-6 md:py-12">
    <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-10">
      <!-- Content -->
      <div>
        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="text-sm font-semibold text-accent-500 uppercase tracking-wider">{problem.data.category}</span>
          <StatusBadge status={problem.data.status} size="md" />
          <span class:list={['text-sm font-medium', priorityColors[problem.data.priority]]}>
            Приоритет: {priorityLabels[problem.data.priority]}
          </span>
        </div>

        <p class="text-base md:text-lg text-accent-600 mb-6 leading-relaxed">{problem.data.summary}</p>

        {hasTemplates && (
          <div class="mb-8">
            <ComplaintCTA slug={problem.id} templateCount={templateCount} variant="banner" />
          </div>
        )}

        <!-- Article -->
        <article class="prose md:prose-lg max-w-none
          prose-headings:text-primary-950
          prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-accent-200
          md:prose-h2:text-2xl md:prose-h2:mt-12 md:prose-h2:mb-5
          prose-h3:text-base prose-h3:mt-6 prose-h3:mb-2
          md:prose-h3:text-lg md:prose-h3:mt-8 md:prose-h3:mb-3
          prose-p:text-accent-700 prose-p:leading-relaxed prose-p:text-[15px] md:prose-p:text-base
          prose-strong:text-primary-900
          prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
          prose-table:text-sm
          prose-th:bg-accent-50 prose-th:text-left prose-th:font-semibold
          prose-td:border-b prose-td:border-accent-100
          prose-li:text-accent-700 prose-li:text-[15px] md:prose-li:text-base prose-li:leading-relaxed
          prose-ul:list-disc prose-ul:pl-5 prose-ul:space-y-1
        ">
          <Content />
        </article>

        <!-- Resident quotes -->
        {quotes.length > 0 && (
          <div class="mt-12 pt-8 border-t border-accent-200">
            <h2 class="text-xl font-bold text-primary-950 mb-1">Что говорят жители</h2>
            <p class="text-sm text-accent-500 mb-4">
              Обсуждалось {discussionCount.toLocaleString('ru-RU')} раз в Telegram-чатах
            </p>
            <p class="text-xs text-accent-400 italic mb-6">
              Приводятся мнения жителей из Telegram-чата ЖК. Имена не раскрываются.
            </p>
            <div class="space-y-3">
              {quotes.slice(0, 5).map(quote => (
                <blockquote class="border-l-4 border-primary-200 pl-4 py-2 text-sm text-accent-700 bg-accent-50 rounded-r-lg">
                  {quote}
                </blockquote>
              ))}
            </div>
          </div>
        )}

        <!-- Solutions -->
        {solutions.length > 0 && (
          <div class="mt-10 pt-8 border-t border-accent-200">
            <h2 class="text-xl font-bold text-primary-950 mb-4">Решения и результаты</h2>
            <div class="space-y-3">
              {solutions.slice(0, 5).map(sol => (
                <div class="flex gap-3 p-3 bg-green-50 rounded-lg border border-green-100">
                  <svg class="w-5 h-5 text-green-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-width="2" stroke-linecap="round"/>
                    <path d="m9 11 3 3L22 4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <div>
                    <p class="text-sm text-accent-700">{sol.text}</p>
                    {sol.date && <span class="text-xs text-accent-400 mt-1 block">{sol.date}</span>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {hasTemplates && (
          <div class="mt-10 pt-8 border-t border-accent-200">
            <ComplaintCTA slug={problem.id} templateCount={templateCount} variant="banner" />
          </div>
        )}

        <!-- Back link -->
        <div class="mt-12 pt-6 border-t border-accent-200">
          <a href="/problems" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-800 font-medium transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 12H5" stroke-width="2" stroke-linecap="round"/><path d="m12 19-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Все проблемы
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 bg-white rounded-2xl border border-accent-200 p-5 space-y-4">
          <h4 class="text-sm font-semibold text-accent-500 uppercase tracking-wider">Информация</h4>
          {discussionCount > 0 && (
            <div class="bg-primary-50 rounded-lg p-3 text-center">
              <div class="text-2xl font-bold text-primary-700">{discussionCount.toLocaleString('ru-RU')}</div>
              <div class="text-xs text-primary-500">упоминаний в чатах</div>
            </div>
          )}
          <div>
            <dt class="text-xs text-accent-400 mb-1">Категория</dt>
            <dd class="font-medium text-primary-950 text-sm">{problem.data.category}</dd>
          </div>
          <div>
            <dt class="text-xs text-accent-400 mb-1">Статус</dt>
            <dd><StatusBadge status={problem.data.status} size="sm" /></dd>
          </div>
          <div>
            <dt class="text-xs text-accent-400 mb-1">Приоритет</dt>
            <dd class:list={['font-medium text-sm', priorityColors[problem.data.priority]]}>{priorityLabels[problem.data.priority]}</dd>
          </div>
          {lawLink && (
            <>
              <hr class="border-accent-100" />
              <div>
                <dt class="text-xs text-accent-400 mb-1">Нормативная база</dt>
                <dd class="text-sm text-accent-700">{lawLink.laws.join(', ')}</dd>
              </div>
              <div>
                <dt class="text-xs text-accent-400 mb-1">Куда жаловаться</dt>
                <dd class="text-sm text-accent-700">{lawLink.instance}</dd>
              </div>
            </>
          )}
          <hr class="border-accent-100" />
          {hasTemplates && (
            <ComplaintCTA slug={problem.id} templateCount={templateCount} variant="compact" />
          )}
          <a href="/complaints" class="block text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">
            Куда жаловаться &rarr;
          </a>
          <a href="/rights" class="block text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">
            Ваши права &rarr;
          </a>
          <a href="/contract" class="block text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">
            Договор УК &rarr;
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  /* Tables: card wrapper with horizontal scroll */
  article.prose :where(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--color-accent-200);
    border-radius: 0.75rem;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }
  /* Only headers stay single-line; data cells can wrap */
  article.prose :where(th) {
    white-space: nowrap;
  }
  /* h3: sage green left border — visual section separator */
  article.prose :where(h3) {
    padding-left: 0.75rem;
    border-left: 3px solid var(--color-primary-400);
  }
  /* List markers: sage green instead of grey */
  article.prose :where(li)::marker {
    color: var(--color-primary-500);
  }
  article.prose :where(ol > li)::marker {
    font-weight: 600;
  }
  @media (max-width: 767px) {
    article.prose :where(table) {
      font-size: 0.8125rem;
    }
    article.prose :where(th, td) {
      padding: 0.5rem 0.75rem;
    }
  }
</style>
