---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProblemCard from '../../components/ProblemCard.astro';
import { getCollection } from 'astro:content';

const allProblems = await getCollection('problems');
const problems = allProblems.sort((a, b) => a.data.order - b.data.order);

const categories = [...new Set(problems.map(p => p.data.category))];
---

<BaseLayout title="Проблемы" description="Каталог проблем ЖК Skandi Klubb — безопасность, технические, финансовые, организационные">
  <PageHeader
    title="Проблемы ЖК"
    description="Выявленные проблемы, сгруппированные по категориям. Нажмите на карточку для подробной информации."
    breadcrumbs={[{ label: 'Проблемы' }]}
  />

  <section class="max-w-6xl mx-auto px-4 py-12">
    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <button class="category-btn active px-4 py-2 rounded-full text-sm font-medium bg-primary-600 text-white transition-all duration-200" data-category="all">
        Все ({problems.length})
      </button>
      {categories.map(cat => {
        const count = problems.filter(p => p.data.category === cat).length;
        return (
          <button
            class="category-btn px-4 py-2 rounded-full text-sm font-medium bg-white text-accent-700 border border-accent-200 hover:border-primary-300 hover:text-primary-700 transition-all duration-200"
            data-category={cat}
          >
            {cat} ({count})
          </button>
        );
      })}
    </div>

    <!-- Problems grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="problems-grid">
      {problems.map((problem, i) => (
        <div class="problem-item animate-fade-in" data-category={problem.data.category} style={`transition-delay: ${i * 50}ms`}>
          <ProblemCard
            title={problem.data.title}
            slug={problem.id}
            category={problem.data.category}
            priority={problem.data.priority}
            status={problem.data.status === 'collecting' ? 'Сбор информации' :
                    problem.data.status === 'preparing' ? 'Подготовка' :
                    problem.data.status === 'investigation' ? 'Требуются изыскания' : 'Готово'}
            summary={problem.data.summary}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.category-btn');
  const items = document.querySelectorAll('.problem-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.category;

      buttons.forEach(b => {
        b.classList.remove('active', 'bg-primary-600', 'text-white');
        b.classList.add('bg-white', 'text-accent-700', 'border', 'border-accent-200');
      });
      btn.classList.add('active', 'bg-primary-600', 'text-white');
      btn.classList.remove('bg-white', 'text-accent-700', 'border', 'border-accent-200');

      items.forEach(item => {
        const el = item as HTMLElement;
        if (cat === 'all' || el.dataset.category === cat) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
