---
import BaseLayout from '../layouts/BaseLayout.astro';
import { managementCompany } from '../data/house';
---

<BaseLayout title="Управляющая компания" description="ООО ЭКВИДА-СЕРВИС — реквизиты, контакты, режим работы">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">Управляющая компания</h1>

    <!-- Company info -->
    <div class="bg-white rounded-xl border border-accent-200 overflow-hidden mb-8">
      <div class="bg-primary-50 px-6 py-4 border-b border-accent-200">
        <h2 class="text-xl font-bold text-primary-900">{managementCompany.name}</h2>
      </div>
      <div class="p-6">
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
          <div>
            <dt class="text-sm text-accent-500">ИНН</dt>
            <dd class="font-medium font-mono">{managementCompany.inn}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">ОГРН</dt>
            <dd class="font-medium font-mono">{managementCompany.ogrn}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Юридический адрес</dt>
            <dd class="font-medium text-sm">{managementCompany.legalAddress}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Адрес офиса</dt>
            <dd class="font-medium text-sm">{managementCompany.officeAddress}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Директор</dt>
            <dd class="font-medium">{managementCompany.director}</dd>
            <dd class="text-xs text-accent-400">с {managementCompany.directorSince}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Управляет домом с</dt>
            <dd class="font-medium">{managementCompany.managingSince}</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Contacts -->
    <div class="bg-white rounded-xl border border-accent-200 overflow-hidden mb-8">
      <div class="bg-primary-50 px-6 py-4 border-b border-accent-200">
        <h2 class="text-xl font-bold text-primary-900">Контакты</h2>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-primary-50 rounded-lg p-5">
            <h3 class="font-bold text-primary-900 mb-2">Диспетчер</h3>
            <a
              href={`tel:${managementCompany.phone.replace(/[^\d+]/g, '')}`}
              class="text-2xl font-bold text-primary-600 hover:text-primary-800 transition-colors"
            >
              {managementCompany.phone}
            </a>
          </div>
          <div class="bg-accent-50 rounded-lg p-5">
            <h3 class="font-bold text-primary-900 mb-2">Email</h3>
            <a
              href={`mailto:${managementCompany.email}`}
              class="text-lg text-primary-600 hover:text-primary-800 transition-colors"
            >
              {managementCompany.email}
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Schedule -->
    <div class="bg-white rounded-xl border border-accent-200 overflow-hidden">
      <div class="bg-primary-50 px-6 py-4 border-b border-accent-200">
        <h2 class="text-xl font-bold text-primary-900">Режим работы офиса</h2>
      </div>
      <div class="p-6">
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-green-500 shrink-0"></div>
            <span>{managementCompany.schedule.weekdays}</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-green-500 shrink-0"></div>
            <span>{managementCompany.schedule.friday}</span>
          </div>
          <div class="flex items-center gap-3 mt-4 p-3 bg-yellow-50 rounded-lg border border-yellow-200">
            <div class="w-2 h-2 rounded-full bg-yellow-500 shrink-0"></div>
            <span class="font-medium text-yellow-800">{managementCompany.schedule.reception}</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
