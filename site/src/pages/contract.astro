---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContractSection from '../components/ContractSection.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import IconInfo from '../components/icons/IconInfo.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconClock from '../components/icons/IconClock.astro';
import IconFileText from '../components/icons/IconFileText.astro';
import {
  contractMeta,
  residentRights,
  checklist,
  payments,
  paymentNotes,
  contractSections,
} from '../data/contract';

const rightIcons: Record<string, any> = {
  shield: IconShield,
  info: IconInfo,
  clock: IconClock,
  filetext: IconFileText,
};

const violatedCount = checklist.filter(c => c.status === 'violated').length;
const partialCount = checklist.filter(c => c.status === 'partial').length;
---

<BaseLayout title="Договор управления" description="Договор управления МКД №18А — полный текст, права жителей, чеклист обязательств УК">
  <PageHeader
    title="Договор управления МКД"
    description="Договор №18А — полный текст с анализом выполнения"
    breadcrumbs={[{ label: 'Договор' }]}
  />

  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-10">
      <!-- Main content -->
      <div>
        <!-- Meta block -->
        <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-6 mb-8">
          <h2 class="text-lg font-bold text-primary-950 mb-4">Основные данные</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div class="bg-accent-50 rounded-xl p-4">
              <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Номер</dt>
              <dd class="font-semibold text-primary-950">№{contractMeta.number}</dd>
            </div>
            <div class="bg-accent-50 rounded-xl p-4">
              <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">УК</dt>
              <dd class="font-semibold text-primary-950 text-sm">{contractMeta.managingOrg}</dd>
            </div>
            <div class="bg-accent-50 rounded-xl p-4">
              <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Срок</dt>
              <dd class="font-semibold text-primary-950">{contractMeta.term}</dd>
            </div>
          </div>
          <p class="text-sm text-accent-600 mt-4 flex items-start gap-2">
            <IconInfo size={16} class="text-primary-500 shrink-0 mt-0.5" />
            {contractMeta.prolongation}
          </p>
        </div>

        <!-- Key resident rights -->
        <h2 class="text-2xl font-bold text-primary-950 mb-4" id="rights">Ключевые права жителей</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
          {residentRights.map((right) => {
            const IconComponent = rightIcons[right.icon];
            return (
              <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-5">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-9 h-9 rounded-lg bg-primary-50 flex items-center justify-center">
                    <IconComponent size={18} class="text-primary-600" />
                  </div>
                  <h3 class="font-bold text-primary-950">{right.title}</h3>
                </div>
                <p class="text-sm text-accent-600 leading-relaxed mb-2">{right.description}</p>
                <span class="text-xs text-primary-500 font-medium">{right.clause}</span>
              </div>
            );
          })}
        </div>

        <!-- Checklist -->
        <h2 class="text-2xl font-bold text-primary-950 mb-2" id="checklist">Выполняет ли УК обязательства?</h2>
        <p class="text-sm text-accent-600 mb-4">
          Анализ выполнения обязательств УК по разделу 3.1 договора:
          <span class="text-red-500 font-medium">{violatedCount} нарушений</span>,
          <span class="text-amber-500 font-medium">{partialCount} частично</span>
        </p>
        <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-6 mb-10">
          {checklist.map((item) => (
            <ChecklistItem
              id={item.id}
              obligation={item.obligation}
              clause={item.clause}
              status={item.status}
              comment={item.comment}
            />
          ))}
        </div>

        <!-- Payments -->
        <h2 class="text-2xl font-bold text-primary-950 mb-4" id="payments">Структура платежей</h2>
        <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-6 mb-4">
          <div class="space-y-4">
            {payments.map((p) => (
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 rounded-full bg-primary-400 mt-2 shrink-0"></div>
                <div>
                  <h4 class="text-sm font-semibold text-primary-950">{p.name}</h4>
                  <p class="text-sm text-accent-600">{p.description}</p>
                  <span class="text-xs text-accent-400">{p.basis}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="animate-fade-in bg-amber-50 rounded-2xl border border-amber-200 p-5 mb-10">
          <h4 class="text-sm font-semibold text-amber-800 mb-2 flex items-center gap-2">
            <IconInfo size={16} class="text-amber-500" />
            Важно знать
          </h4>
          <ul class="space-y-1.5">
            {paymentNotes.map((note) => (
              <li class="text-sm text-amber-700 flex items-start gap-2">
                <span class="text-amber-400 mt-1 shrink-0">&bull;</span>
                {note}
              </li>
            ))}
          </ul>
        </div>

        <!-- Full text -->
        <h2 class="text-2xl font-bold text-primary-950 mb-4" id="fulltext">Полный текст договора</h2>
        <p class="text-sm text-accent-600 mb-6">
          12 разделов. Раскройте нужный раздел для просмотра содержания.
        </p>
        <div class="space-y-3 mb-10">
          {contractSections.map((section) => (
            <ContractSection
              number={section.number}
              title={section.title}
              content={section.content}
            />
          ))}
        </div>

        <!-- Back link -->
        <div class="mt-8 pt-6 border-t border-accent-200">
          <a href="/" class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-800 font-medium transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 12H5" stroke-width="2" stroke-linecap="round"/><path d="m12 19-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            На главную
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-4">
          <div class="bg-white rounded-2xl border border-accent-200 p-5">
            <h4 class="text-sm font-semibold text-accent-500 uppercase tracking-wider mb-3">Содержание</h4>
            <nav class="space-y-2">
              <a href="#rights" class="block text-sm text-accent-600 hover:text-primary-600 transition-colors">Права жителей</a>
              <a href="#checklist" class="block text-sm text-accent-600 hover:text-primary-600 transition-colors">Чеклист УК</a>
              <a href="#payments" class="block text-sm text-accent-600 hover:text-primary-600 transition-colors">Платежи</a>
              <a href="#fulltext" class="block text-sm text-accent-600 hover:text-primary-600 transition-colors">Полный текст</a>
            </nav>
          </div>
          <div class="bg-white rounded-2xl border border-accent-200 p-5">
            <h4 class="text-sm font-semibold text-accent-500 uppercase tracking-wider mb-3">Связанные</h4>
            <nav class="space-y-2">
              <a href="/rights" class="block text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">Ваши права &rarr;</a>
              <a href="/complaints" class="block text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">Куда жаловаться &rarr;</a>
              <a href="/problems" class="block text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">Проблемы дома &rarr;</a>
            </nav>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
