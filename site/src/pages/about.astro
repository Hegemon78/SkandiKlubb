---
import BaseLayout from '../layouts/BaseLayout.astro';
import { house } from '../data/house';
---

<BaseLayout title="О доме" description="Информация о доме ЖК Skandi Klubb — адрес, структура, площадь, застройщик">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">О доме</h1>

    <!-- Main info -->
    <div class="bg-white rounded-xl border border-accent-200 overflow-hidden mb-8">
      <div class="bg-primary-50 px-6 py-4 border-b border-accent-200">
        <h2 class="text-xl font-bold text-primary-900">Основная информация</h2>
      </div>
      <div class="p-6">
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
          <div>
            <dt class="text-sm text-accent-500">Адрес</dt>
            <dd class="font-medium">{house.address}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">ЖК</dt>
            <dd class="font-medium">{house.name}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Застройщик</dt>
            <dd class="font-medium">{house.developer}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Год постройки</dt>
            <dd class="font-medium">{house.yearBuilt}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Район</dt>
            <dd class="font-medium">{house.district}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Кадастровый номер</dt>
            <dd class="font-medium font-mono text-sm">{house.cadastralNumber}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Общая площадь</dt>
            <dd class="font-medium">
              {house.totalArea}
              <span class="text-xs text-yellow-600 ml-1">({house.totalAreaNote})</span>
            </dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Количество квартир</dt>
            <dd class="font-medium">
              {house.apartments}
              <span class="text-xs text-yellow-600 ml-1">({house.apartmentsNote})</span>
            </dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Подъездов (парадных)</dt>
            <dd class="font-medium">{house.entrances}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Лифтов</dt>
            <dd class="font-medium">{house.elevators}</dd>
          </div>
          <div>
            <dt class="text-sm text-accent-500">Этажность</dt>
            <dd class="font-medium">{house.floors}</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Structure -->
    <div class="bg-white rounded-xl border border-accent-200 overflow-hidden mb-8">
      <div class="bg-primary-50 px-6 py-4 border-b border-accent-200">
        <h2 class="text-xl font-bold text-primary-900">Структура дома (4 очереди)</h2>
      </div>
      <div class="p-6">
        <p class="text-sm text-accent-600 mb-4">
          Дом фактически состоит из 4 корпусов (очередей) под одним адресом.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {house.queues.map(q => (
            <div class="bg-accent-50 rounded-lg p-4 text-center">
              <div class="text-lg font-bold text-primary-800">{q.number} очередь</div>
              <div class="text-sm text-accent-600">Парадные {q.entrances}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Facilities -->
    <div class="bg-white rounded-xl border border-accent-200 overflow-hidden">
      <div class="bg-primary-50 px-6 py-4 border-b border-accent-200">
        <h2 class="text-xl font-bold text-primary-900">Дополнительные помещения</h2>
      </div>
      <div class="p-6">
        <div class="space-y-4">
          {house.facilities.map(f => (
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-primary-500 mt-2 shrink-0"></div>
              <div>
                <span class="font-medium">{f.type}</span>
                <span class="text-accent-600"> — {f.description}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
