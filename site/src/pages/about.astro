---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import StatBar from '../components/StatBar.astro';
import { house } from '../data/house';
---

<BaseLayout title="Дом" description="Паспорт дома ЖК Skandi Klubb — структура, очереди, площадь, застройщик">
  <PageHeader
    title="Паспорт дома"
    description="ЖК Skandi Klubb — основные характеристики, структура и инфраструктура"
    breadcrumbs={[{ label: 'Дом' }]}
  />

  <section class="max-w-5xl mx-auto px-4 py-12">
    <!-- Stat bar: 3 ключевых показателя -->
    <div class="animate-fade-in mb-8">
      <StatBar stats={[
        { value: house.apartments, label: 'квартир' },
        { value: house.entrances, label: 'парадных' },
        { value: house.yearBuilt, label: 'год постройки' },
      ]} />
    </div>

    <!-- Структура дома: компактная таблица + inline помещения -->
    <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-accent-100">
        <h2 class="text-xl font-bold text-primary-950">Структура дома (4 очереди)</h2>
        <p class="text-sm text-accent-600 mt-1">
          Дом фактически состоит из 4 корпусов (очередей) под одним адресом.
        </p>
      </div>
      <div class="px-6 py-4">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-accent-100">
                <th class="text-xs font-medium text-accent-500 uppercase tracking-wider text-left py-2 pr-4">Очередь</th>
                <th class="text-xs font-medium text-accent-500 uppercase tracking-wider text-left py-2 pr-4">Парадные</th>
                <th class="text-xs font-medium text-accent-500 uppercase tracking-wider text-left py-2 pr-4">Этажи</th>
                <th class="text-xs font-medium text-accent-500 uppercase tracking-wider text-left py-2">Квартиры</th>
              </tr>
            </thead>
            <tbody>
              {house.queues.map(q => (
                <tr class="even:bg-primary-50/30">
                  <td class="py-2 pr-4 font-medium text-primary-950">{q.number}-я ({q.count} шт.)</td>
                  <td class="py-2 pr-4 text-primary-950">{q.entrances}</td>
                  <td class="py-2 pr-4 text-primary-950">{q.floors}</td>
                  <td class="py-2 text-primary-950">{q.approxApartments}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <!-- Помещения: inline после таблицы -->
        <p class="text-sm text-accent-600 mt-4 pt-3 border-t border-accent-100">
          <span class="font-medium text-primary-800">Помещения:</span>{' '}
          {house.facilities.map((f, i) => (
            <>{i > 0 && ' · '}{f.type.toLowerCase()}</>
          ))}
        </p>
      </div>
    </div>

    <!-- Реквизиты: всегда открыты -->
    <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-accent-100">
        <h2 class="text-xl font-bold text-primary-950">Реквизиты и справочные данные</h2>
      </div>
      <div class="p-6">
        <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5">
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Адрес</dt>
            <dd class="font-medium text-primary-950">{house.address}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">ЖК</dt>
            <dd class="font-medium text-primary-950">{house.name}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Застройщик</dt>
            <dd class="font-medium text-primary-950">{house.developer}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Район</dt>
            <dd class="font-medium text-primary-950">{house.district}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Кадастровый номер</dt>
            <dd class="font-medium font-mono text-sm text-primary-950">{house.cadastralNumber}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Общая площадь</dt>
            <dd class="font-medium text-primary-950">
              {house.totalArea}
              <span class="text-xs text-amber-600 ml-1">({house.totalAreaNote})</span>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Количество квартир</dt>
            <dd class="font-medium text-primary-950">
              {house.apartments}
              <span class="text-xs text-amber-600 ml-1">({house.apartmentsNote})</span>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-1">Этажность</dt>
            <dd class="font-medium text-primary-950">{house.floors}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>
