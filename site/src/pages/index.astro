---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuickLinkCard from '../components/QuickLinkCard.astro';
import ProblemMiniCard from '../components/ProblemMiniCard.astro';
import IconHome from '../components/icons/IconHome.astro';
import IconBuilding from '../components/icons/IconBuilding.astro';
import IconAlertTriangle from '../components/icons/IconAlertTriangle.astro';
import IconVote from '../components/icons/IconVote.astro';
import IconFileText from '../components/icons/IconFileText.astro';
import IconGavel from '../components/icons/IconGavel.astro';
import IconScale from '../components/icons/IconScale.astro';
import IconHelpCircle from '../components/icons/IconHelpCircle.astro';
import IconPhone from '../components/icons/IconPhone.astro';
import IconMail from '../components/icons/IconMail.astro';
import IconClock from '../components/icons/IconClock.astro';
import { house, managementCompany } from '../data/house';
import { getCollection } from 'astro:content';
import summary from '../data/generated/summary.json';

const allProblems = await getCollection('problems');
const problems = allProblems.sort((a, b) => a.data.order - b.data.order);
const highPriority = problems.filter(p => p.data.priority === 'high');
const topProblems = highPriority.slice(0, 3);
---

<BaseLayout title="Главная" description="Информационный портал для жителей ЖК Skandi Klubb — Аптекарский проспект, 18" transparentHeader={true}>
  <!-- Hero -->
  <section class="relative bg-primary-950 text-white pt-18 pb-16 md:pt-24 md:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-primary-900/80 to-primary-950"></div>
    <!-- Geometric pattern -->
    <div class="absolute inset-0 opacity-[0.035]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>

    <div class="relative max-w-6xl mx-auto px-4 text-center">
      <!-- Desktop: full brand name -->
      <h1 class="hidden md:block text-5xl font-extrabold text-white mb-2 tracking-tight">
        Skandi Klubb
      </h1>
      <!-- Mobile: address as hero (brand already in header) -->
      <h1 class="md:hidden text-2xl font-bold text-white mb-1">
        Аптекарский проспект, 18
      </h1>
      <p class="hidden md:block text-lg text-primary-200/90 font-light">{house.address}</p>
      <p class="text-sm md:text-base text-primary-300/80 mt-1">Информация, документы, жалобы</p>
    </div>

    <!-- Wave transition -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60V30C240 8 480 0 720 15C960 30 1200 38 1440 22V60H0Z" fill="#FAFAF7"/>
      </svg>
    </div>
  </section>

  <!-- Quick links with facts -->
  <section class="max-w-6xl mx-auto px-4 -mt-4 relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-2.5 md:gap-4">
      <QuickLinkCard href="/about" title="Дом" fact="1 222 кв.">
        <IconHome size={18} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/management" title="УК" fact="Контакты">
        <IconBuilding size={18} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/problems" title="Проблемы" fact={`${problems.length} проблем`}>
        <IconAlertTriangle size={18} class="text-amber-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/faq" title="FAQ" fact={`${summary.faqCount.toLocaleString('ru-RU')} FAQ`}>
        <IconHelpCircle size={18} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/contract" title="Договор" fact="Анализ">
        <IconGavel size={18} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/rights" title="Ваши права" fact="Памятка">
        <IconScale size={18} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/oss" title="ОСС 2025" fact="Повестка">
        <IconVote size={18} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/generator" title="Генератор" fact="Создать">
        <IconFileText size={18} class="text-amber-600" />
      </QuickLinkCard>
    </div>
  </section>

  <!-- Top problems -->
  <section class="max-w-6xl mx-auto px-4 pt-8 pb-12 md:pt-12 md:pb-16">
    <div class="animate-fade-in">
      <div class="flex items-center justify-between mb-4 md:mb-6">
        <h2 class="text-lg md:text-2xl font-bold text-primary-950">Острые проблемы</h2>
        <a href="/problems" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors inline-flex items-center gap-1">
          Все проблемы
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2.5 md:gap-4">
        {topProblems.map(p => (
          <ProblemMiniCard
            title={p.data.title}
            slug={p.id}
            category={p.data.category}
            summary={p.data.summary}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Quick contacts -->
  <section class="max-w-6xl mx-auto px-4 pb-10 md:pb-16">
    <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-6">
      <h2 class="text-lg font-bold text-primary-950 mb-4">Контакты диспетчерской УК</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a
          href={`tel:${managementCompany.phone.replace(/[^\d+]/g, '')}`}
          class="flex items-center gap-3 text-sm text-accent-700 hover:text-primary-700 transition-colors"
        >
          <div class="w-9 h-9 rounded-lg bg-primary-50 flex items-center justify-center shrink-0">
            <IconPhone size={18} class="text-primary-600" />
          </div>
          <div>
            <div class="text-xs text-accent-500">Диспетчер</div>
            <div class="font-semibold">{managementCompany.phone}</div>
          </div>
        </a>
        <a
          href={`mailto:${managementCompany.email}`}
          class="flex items-center gap-3 text-sm text-accent-700 hover:text-primary-700 transition-colors"
        >
          <div class="w-9 h-9 rounded-lg bg-accent-50 flex items-center justify-center shrink-0">
            <IconMail size={18} class="text-accent-600" />
          </div>
          <div>
            <div class="text-xs text-accent-500">Email</div>
            <div class="font-semibold">{managementCompany.email}</div>
          </div>
        </a>
        <div class="flex items-center gap-3 text-sm text-accent-700">
          <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
            <IconClock size={18} class="text-amber-600" />
          </div>
          <div>
            <div class="text-xs text-accent-500">Приём граждан</div>
            <div class="font-semibold">Чт, 09:00-16:00</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
