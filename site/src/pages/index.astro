---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuickLinkCard from '../components/QuickLinkCard.astro';
import ProblemMiniCard from '../components/ProblemMiniCard.astro';
import IconHome from '../components/icons/IconHome.astro';
import IconBuilding from '../components/icons/IconBuilding.astro';
import IconAlertTriangle from '../components/icons/IconAlertTriangle.astro';
import IconMegaphone from '../components/icons/IconMegaphone.astro';
import IconVote from '../components/icons/IconVote.astro';
import IconFileText from '../components/icons/IconFileText.astro';
import IconGavel from '../components/icons/IconGavel.astro';
import IconScale from '../components/icons/IconScale.astro';
import IconHelpCircle from '../components/icons/IconHelpCircle.astro';
import IconPhone from '../components/icons/IconPhone.astro';
import IconMail from '../components/icons/IconMail.astro';
import IconClock from '../components/icons/IconClock.astro';
import { house, managementCompany } from '../data/house';
import { getCollection } from 'astro:content';
import summary from '../data/generated/summary.json';

const allProblems = await getCollection('problems');
const problems = allProblems.sort((a, b) => a.data.order - b.data.order);
const highPriority = problems.filter(p => p.data.priority === 'high');
const topProblems = highPriority.slice(0, 3);
---

<BaseLayout title="Главная" description="Информационный портал для жителей ЖК Skandi Klubb — Аптекарский проспект, 18" transparentHeader={true}>
  <!-- Hero — compact -->
  <section class="relative bg-primary-950 text-white pt-24 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900 via-primary-950 to-primary-900"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-primary-700)_0%,_transparent_50%)] opacity-40"></div>

    <div class="relative max-w-6xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur rounded-full px-4 py-1.5 text-sm text-primary-200 mb-6">
        <span class="w-2 h-2 rounded-full bg-primary-400"></span>
        Инициатива жителей
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-3 tracking-tight">
        Skandi Klubb
      </h1>
      <p class="text-lg text-primary-200 mb-2 font-light">{house.address}</p>
      <p class="text-sm text-primary-400">
        {summary.totalMessages.toLocaleString('ru-RU')} сообщений проанализировано &middot; {summary.faqCount.toLocaleString('ru-RU')} вопросов &middot; {problems.length} проблем
      </p>
    </div>

    <!-- Wave transition -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60V30C240 8 480 0 720 15C960 30 1200 38 1440 22V60H0Z" fill="#FAFAF7"/>
      </svg>
    </div>
  </section>

  <!-- Quick links with facts -->
  <section class="max-w-6xl mx-auto px-4 -mt-4 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
      <QuickLinkCard href="/about" title="Дом" description="Паспорт здания, структура, очереди" fact={`4 очереди, ${house.entrances} парадных`}>
        <IconHome size={22} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/management" title="УК" description="ЭКВИДА-СЕРВИС: контакты, обязанности" fact={managementCompany.phone}>
        <IconBuilding size={22} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/problems" title="Проблемы" description="Каталог проблем с описанием и статусами" fact={`${problems.length} проблем | ${highPriority.length} критических`}>
        <IconAlertTriangle size={22} class="text-amber-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/faq" title="FAQ" description="Вопросы жителей из Telegram-чатов" fact={`${summary.faqCount.toLocaleString('ru-RU')} вопросов | ${(summary.topSubcategories as any[]).length} тем`}>
        <IconHelpCircle size={22} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/contract" title="Договор" description="Текст договора с УК, чеклист обязательств" fact="12 разделов | 14 пунктов чеклиста">
        <IconGavel size={22} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/rights" title="Ваши права" description="Кворум, реестр, законодательная база" fact="12 законов | таблица кворумов">
        <IconScale size={22} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/oss" title="ОСС 2025" description="Проект повестки, кворумы, статусы" fact="13 вопросов в 4 блоках">
        <IconVote size={22} class="text-primary-600" />
      </QuickLinkCard>

      <QuickLinkCard href="/generator" title="Генератор жалоб" description="Генерация обращений в инстанции" fact={`${problems.length} проблем | 8 инстанций`}>
        <IconFileText size={22} class="text-primary-600" />
      </QuickLinkCard>
    </div>
  </section>

  <!-- Top problems -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="animate-fade-in">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-primary-950">Приоритетные проблемы</h2>
        <a href="/problems" class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors inline-flex items-center gap-1">
          Все проблемы
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {topProblems.map(p => (
          <ProblemMiniCard
            title={p.data.title}
            slug={p.id}
            category={p.data.category}
            summary={p.data.summary}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Quick contacts -->
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <div class="animate-fade-in bg-white rounded-2xl border border-accent-200 p-6">
      <h2 class="text-lg font-bold text-primary-950 mb-4">Контакты диспетчерской УК</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a
          href={`tel:${managementCompany.phone.replace(/[^\d+]/g, '')}`}
          class="flex items-center gap-3 text-sm text-accent-700 hover:text-primary-700 transition-colors"
        >
          <div class="w-9 h-9 rounded-lg bg-primary-50 flex items-center justify-center shrink-0">
            <IconPhone size={18} class="text-primary-600" />
          </div>
          <div>
            <div class="text-xs text-accent-500">Диспетчер</div>
            <div class="font-semibold">{managementCompany.phone}</div>
          </div>
        </a>
        <a
          href={`mailto:${managementCompany.email}`}
          class="flex items-center gap-3 text-sm text-accent-700 hover:text-primary-700 transition-colors"
        >
          <div class="w-9 h-9 rounded-lg bg-accent-50 flex items-center justify-center shrink-0">
            <IconMail size={18} class="text-accent-600" />
          </div>
          <div>
            <div class="text-xs text-accent-500">Email</div>
            <div class="font-semibold">{managementCompany.email}</div>
          </div>
        </a>
        <div class="flex items-center gap-3 text-sm text-accent-700">
          <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
            <IconClock size={18} class="text-amber-600" />
          </div>
          <div>
            <div class="text-xs text-accent-500">Приём граждан</div>
            <div class="font-semibold">Чт, 09:00-16:00</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
